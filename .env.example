# Required for the setup page
SETUP_PASSWORD=replace-me

# Required for the auth bridge into the native OpenFang dashboard
OPENFANG_API_KEY=replace-me-too

# Bootstrap defaults for generated /data/config.toml
OPENFANG_DEFAULT_PROVIDER=anthropic
OPENFANG_DEFAULT_MODEL=claude-sonnet-4-20250514
OPENFANG_DEFAULT_API_KEY_ENV=ANTHROPIC_API_KEY
OPENFANG_LOG_LEVEL=info
OPENFANG_MEMORY_DECAY_RATE=0.05
OPENFANG_ENABLE_NETWORK=false

# Add at least one provider key for a smooth first run
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=

# Optional channel tokens
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
